{
  "private": true,
  "name": "example-blog-ssg",
  "scripts": {
    "build:css": "pnpm exec tailwindcss -i ./styles/input.css -o ./dist/styles.css --minify",
    "build:content": "node scripts/build-content.js",
    "prerender": "pnpm exec spago run",
    "bundle": "pnpm exec spago bundle",
    "build": "node scripts/build.js",
    "start": "pnpm run build && serve dist"
  },
  "devDependencies": {
    "purescript": "0.15.15",
    "spago": "^1.0.4",
    "@tailwindcss/cli": "^4.1.4",
    "tailwindcss": "^4.1.4",
    "esbuild": "^0.25.0",
    "front-matter": "^4.0.2",
    "js-yaml": "^4.1.0",
    "markdown-it": "^14.1.0",
    "mkdirp": "^3.0.1",
    "serve": "^14.0.0"
  }
}
